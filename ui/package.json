{
  "name": "ui",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "style-check": "biome check src vite.config.ts tsconfig.json tsconfig.app.json tsconfig.node.json package.json biome.json",
    "style-fix": "biome check --write src vite.config.ts tsconfig.json tsconfig.app.json tsconfig.node.json package.json biome.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@glideapps/glide-data-grid": "^6.0.3",
    "preact": "^10.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@preact/preset-vite": "^2.10.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^24.12.0",
    "jsdom": "^27.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.0.0"
  }
}
