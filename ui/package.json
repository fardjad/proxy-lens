{
  "name": "ui",
  "private": true,
  "version": "0.4.2",
  "type": "module",
  "scripts": {
    "dev": "PUBLIC_PROXYLENS_DEV_PROXY=1 bun run dev-server.ts",
    "build": "tsc -p tsconfig.build.json && bun run build.ts",
    "preview": "bun run dev-server.ts --dist",
    "style-check": "biome check src build.ts dev-server.ts bunfig.toml tsconfig.json tsconfig.build.json package.json biome.json",
    "style-fix": "biome check --write src build.ts dev-server.ts bunfig.toml tsconfig.json tsconfig.build.json package.json biome.json",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@glideapps/glide-data-grid": "^6.0.3",
    "preact": "^10.29.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "bun-types": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
