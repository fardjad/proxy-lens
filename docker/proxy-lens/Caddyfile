{
	auto_https off
	admin off
}

:{$PROXYLENS_UI_PORT:8080} {
	route {
		handle_path /api/* {
			reverse_proxy 127.0.0.1:{$PROXYLENS_SERVER_PORT:8000}
		}

		@runtime_config path /runtime-config.js
		header @runtime_config Cache-Control "no-store"

		handle {
			root * /proxy-lens/ui
			try_files {path} /index.html
			file_server
		}
	}
}
